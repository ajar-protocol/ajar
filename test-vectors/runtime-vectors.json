{
  "ajar_version": "0.1",
  "vectors": [
    {
      "id": "http-manifest-well-known-location",
      "spec_section": "2.1",
      "kind": "http_surface",
      "input": {
        "method": "GET",
        "path": "/.well-known/ajar.json",
        "serves_manifest": true
      },
      "expected": {
        "verdict": "accept"
      }
    },
    {
      "id": "http-manifest-wrong-location",
      "spec_section": "2.1",
      "kind": "http_surface",
      "input": {
        "method": "GET",
        "path": "/ajar.json",
        "serves_manifest": true
      },
      "expected": {
        "verdict": "reject",
        "error_code": "AJAR-POLICY-DENIED"
      }
    },
    {
      "id": "manifest-domain-binding-valid",
      "spec_section": "2.2",
      "kind": "domain_binding",
      "input": {
        "manifest_domain": "examplerail.example",
        "request_domain": "examplerail.example",
        "owner_key_present": true,
        "proof": "dns-txt"
      },
      "expected": {
        "verdict": "accept"
      }
    },
    {
      "id": "manifest-domain-binding-mismatch",
      "spec_section": "2.2",
      "kind": "domain_binding",
      "input": {
        "manifest_domain": "examplerail.example",
        "request_domain": "attacker.example",
        "owner_key_present": true,
        "proof": "dns-txt"
      },
      "expected": {
        "verdict": "reject",
        "error_code": "AJAR-VERIFY-DOMAIN-BINDING"
      }
    },
    {
      "id": "signature-kid-known",
      "spec_section": "2.4",
      "kind": "kid_resolution",
      "input": {
        "kid": "owner-2026",
        "known_kids": ["owner-2026", "content-2026-07"]
      },
      "expected": {
        "verdict": "accept"
      }
    },
    {
      "id": "signature-kid-unknown",
      "spec_section": "2.4",
      "kind": "kid_resolution",
      "input": {
        "kid": "unknown-2026",
        "known_kids": ["owner-2026", "content-2026-07"]
      },
      "expected": {
        "verdict": "reject",
        "error_code": "AJAR-VERIFY-UNKNOWN-KID"
      }
    },
    {
      "id": "client-r3-propose-without-simulate",
      "spec_section": "6",
      "kind": "client_action_sequence",
      "input": {
        "action_risk": "R3",
        "attempted_mode": "propose",
        "prior_simulation": false
      },
      "expected": {
        "verdict": "reject",
        "error_code": "AJAR-SIMULATE-REQUIRED"
      }
    },
    {
      "id": "client-r3-propose-after-simulate",
      "spec_section": "6",
      "kind": "client_action_sequence",
      "input": {
        "action_risk": "R3",
        "attempted_mode": "propose",
        "prior_simulation": true
      },
      "expected": {
        "verdict": "accept"
      }
    },
    {
      "id": "simulate-endpoints-equivalent",
      "spec_section": "6",
      "kind": "simulate_equivalence",
      "input": {
        "header_mode_hash": "sha256:simulationResultHash001",
        "subresource_hash": "sha256:simulationResultHash001"
      },
      "expected": {
        "verdict": "accept"
      }
    },
    {
      "id": "simulate-endpoints-diverged",
      "spec_section": "6",
      "kind": "simulate_equivalence",
      "input": {
        "header_mode_hash": "sha256:simulationResultHash001",
        "subresource_hash": "sha256:differentSimulationResultHash001"
      },
      "expected": {
        "verdict": "reject",
        "error_code": "AJAR-SIMULATE-DIVERGED"
      }
    },
    {
      "id": "view-chunks-provenance-tagged",
      "spec_section": "4",
      "kind": "view_provenance",
      "input": {
        "view": "examples/views/blog-home.view.json",
        "origin": "https://notes.example",
        "chunks": [
          {
            "id": "home.title",
            "origin": "https://notes.example",
            "inert": true
          },
          {
            "id": "home.summary",
            "origin": "https://notes.example",
            "inert": true
          }
        ]
      },
      "expected": {
        "verdict": "accept"
      }
    },
    {
      "id": "view-chunk-executable-rejected",
      "spec_section": "4",
      "kind": "view_provenance",
      "input": {
        "view": "examples/views/blog-home.view.json",
        "origin": "https://notes.example",
        "chunks": [
          {
            "id": "home.title",
            "origin": "https://notes.example",
            "inert": true
          },
          {
            "id": "home.summary",
            "origin": "https://notes.example",
            "inert": false
          }
        ]
      },
      "expected": {
        "verdict": "reject",
        "error_code": "AJAR-CLIENT-PROVENANCE"
      }
    },
    {
      "id": "breaking-change-major-bump",
      "spec_section": "13",
      "kind": "version_change",
      "input": {
        "change": "breaking",
        "old_version": "0.1",
        "new_version": "1.0"
      },
      "expected": {
        "verdict": "accept"
      }
    },
    {
      "id": "breaking-change-without-major-bump",
      "spec_section": "13",
      "kind": "version_change",
      "input": {
        "change": "breaking",
        "old_version": "0.1",
        "new_version": "0.2"
      },
      "expected": {
        "verdict": "reject",
        "error_code": "AJAR-VERSION-BREAKING"
      }
    },
    {
      "id": "public-extension-with-aep",
      "spec_section": "13",
      "kind": "aep_requirement",
      "input": {
        "affects_interoperability": true,
        "aep_present": true
      },
      "expected": {
        "verdict": "accept"
      }
    },
    {
      "id": "public-extension-without-aep",
      "spec_section": "13",
      "kind": "aep_requirement",
      "input": {
        "affects_interoperability": true,
        "aep_present": false
      },
      "expected": {
        "verdict": "reject",
        "error_code": "AJAR-AEP-REQUIRED"
      }
    },
    {
      "id": "fallback-r3-without-human",
      "spec_section": "9",
      "kind": "fallback_operation",
      "input": {
        "manifest_present": false,
        "derived_operation_risk": "R3",
        "human_confirmation": false
      },
      "expected": {
        "verdict": "reject",
        "error_code": "AJAR-FALLBACK-HUMAN-REQUIRED"
      }
    },
    {
      "id": "fallback-r3-with-human",
      "spec_section": "9",
      "kind": "fallback_operation",
      "input": {
        "manifest_present": false,
        "derived_operation_risk": "R3",
        "human_confirmation": true
      },
      "expected": {
        "verdict": "accept"
      }
    }
  ]
}
